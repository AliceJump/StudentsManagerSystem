<Window x:Class="StudentsManagerSystem.Views.StudentStatus.GraduationEditWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="毕业信息" Height="390" Width="560" MinWidth="480" MinHeight="350" WindowStartupLocation="CenterOwner">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Border Margin="10" Background="White" CornerRadius="6" Padding="12" BorderBrush="#E6EDF6" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Label Grid.Row="0" Content="学号:"/><TextBox x:Name="txtStudentNo" Grid.Row="0" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="1" Content="姓名:"/><TextBox x:Name="txtStudentName" Grid.Row="1" Grid.Column="1" Margin="4" IsReadOnly="True" Background="#F0F0F0"/>
            <Label Grid.Row="2" Content="毕业日期:"/><DatePicker x:Name="dpGraduationDate" Grid.Row="2" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="3" Content="毕业类型:"/><TextBox x:Name="txtGraduationType" Grid.Row="3" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="4" Content="学位类型:"/><TextBox x:Name="txtDegreeType" Grid.Row="4" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="5" Content="毕业证书号:"/><TextBox x:Name="txtCertificateNo" Grid.Row="5" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="6" Content="学位证书号:"/><TextBox x:Name="txtDegreeNo" Grid.Row="6" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="7" Content="备注:"/><TextBox x:Name="txtRemarks" Grid.Row="7" Grid.Column="1" Margin="4"/>
            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="btnOk" Width="90" Margin="4" Click="btnOk_Click">确定</Button><Button Width="90" Margin="4" Click="btnCancel_Click">取消</Button></StackPanel>
        </Grid>
    </Border>
    </ScrollViewer>
</Window>
