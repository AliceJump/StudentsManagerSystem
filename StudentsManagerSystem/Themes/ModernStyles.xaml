<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window background -->
    <SolidColorBrush x:Key="WindowBackground" Color="#F6F8FA" />
    <SolidColorBrush x:Key="PrimaryAccent" Color="#2B6CB0" />
    <SolidColorBrush x:Key="AccentText" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FieldBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBackground}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="SizeToContent" Value="Manual" />
        <Setter Property="ResizeMode" Value="CanResize" />
        <Setter Property="MinWidth" Value="360" />
        <Setter Property="MinHeight" Value="260" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="#2D3748" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource FieldBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource FieldBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryAccent}" />
        <Setter Property="Foreground" Value="{StaticResource AccentText}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#F7FAFC" />
        <Setter Property="GridLinesVisibility" Value="None" />
    </Style>

</ResourceDictionary>
