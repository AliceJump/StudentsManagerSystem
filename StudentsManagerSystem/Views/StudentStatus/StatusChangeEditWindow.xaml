<Window x:Class="StudentsManagerSystem.Views.StudentStatus.StatusChangeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学籍变动" Height="420" Width="560" MinWidth="480" MinHeight="360" WindowStartupLocation="CenterOwner">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Border Margin="10" Background="White" CornerRadius="6" Padding="12" BorderBrush="#E6EDF6" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Label Grid.Row="0" Content="学号:"/><TextBox x:Name="txtStudentNo" Grid.Row="0" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="1" Content="姓名:"/><TextBox x:Name="txtStudentName" Grid.Row="1" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="2" Content="变动日期:"/><DatePicker x:Name="dpChangeDate" Grid.Row="2" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="3" Content="变动类型:"/><TextBox x:Name="txtChangeType" Grid.Row="3" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="4" Content="原信息:"/><TextBox x:Name="txtOriginalInfo" Grid.Row="4" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="5" Content="新信息:"/><TextBox x:Name="txtNewInfo" Grid.Row="5" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="6" Content="原因:"/><TextBox x:Name="txtReason" Grid.Row="6" Grid.Column="1" Margin="4"/>
            <Label Grid.Row="7" Content="审批状态:"/><ComboBox x:Name="cmbApprovalStatus" Grid.Row="7" Grid.Column="1" Margin="4">
                <ComboBoxItem Content="待审批"/><ComboBoxItem Content="已批准"/><ComboBoxItem Content="已驳回"/>
            </ComboBox>
            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnOk" Width="90" Margin="4" Click="btnOk_Click">确定</Button>
                <Button Width="90" Margin="4" Click="btnCancel_Click">取消</Button>
            </StackPanel>
        </Grid>
    </Border>
    </ScrollViewer>
</Window>
