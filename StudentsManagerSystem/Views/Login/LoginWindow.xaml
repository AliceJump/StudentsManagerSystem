<Window x:Class="StudentsManagerSystem.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录" Height="220" Width="380" MinWidth="360" MinHeight="220" WindowStartupLocation="CenterScreen">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" CornerRadius="6" Padding="12" BorderBrush="#E6EDF6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Content="用户名:" />
                <TextBox x:Name="txtUsername" Grid.Row="0" Grid.Column="1" Margin="6" />

                <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Content="密码:" />
                <PasswordBox x:Name="txtPassword" Grid.Row="1" Grid.Column="1" Margin="6" />

                <TextBlock x:Name="txtError" Grid.Row="2" Grid.ColumnSpan="2" Foreground="Red" Margin="6" />

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnLogin" Width="90" Margin="6" Click="btnLogin_Click">登录</Button>
                    <Button Width="90" Margin="6" Click="btnCancel_Click">取消</Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
