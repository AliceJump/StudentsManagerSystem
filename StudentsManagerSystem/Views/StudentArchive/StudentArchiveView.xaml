<Page x:Class="StudentsManagerSystem.Views.StudentArchive.StudentArchiveView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudentsManagerSystem.Views.StudentArchive"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1100">

    <Page.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部选项卡 -->
        <TabControl x:Name="tabControl" Grid.Row="0" Height="40" 
                    SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="学生基本信息" FontSize="14"/>
            <TabItem Header="家庭信息" FontSize="14"/>
            <TabItem Header="奖励记录" FontSize="14"/>
            <TabItem Header="处分记录" FontSize="14"/>
            <TabItem Header="体检信息" FontSize="14"/>
        </TabControl>

        <!-- 操作按钮区 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15">
            <Button Content="新增" Style="{StaticResource ButtonStyle}" Click="btnAdd_Click"/>
            <Button Content="修改" Style="{StaticResource ButtonStyle}" Click="btnEdit_Click"/>
            <Button Content="删除" Style="{StaticResource DeleteButtonStyle}" Click="btnDelete_Click"/>
            <Button Content="查看详情" Style="{StaticResource ButtonStyle}" Click="btnView_Click"/>
            <Button Content="导入" Style="{StaticResource ButtonStyle}" Click="btnImport_Click"/>
            <Button Content="导出" Style="{StaticResource ButtonStyle}" Click="btnExport_Click"/>
            <Button Content="刷新" Style="{StaticResource ButtonStyle}" Click="btnRefresh_Click"/>
            
            <!-- 搜索框 -->
            <StackPanel Orientation="Horizontal" Margin="30,0,0,0">
                <TextBlock Text="搜索：" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
                <TextBox x:Name="txtSearch" Width="200" Height="32" 
                         VerticalContentAlignment="Center" FontSize="14"/>
                <Button Content="搜索" Style="{StaticResource ButtonStyle}" Click="btnSearch_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="排序：" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbSort" Width="150" Height="32" FontSize="14" SelectionChanged="cmbSort_SelectionChanged">
                <ComboBoxItem Content="学号升序" IsSelected="True"/>
                <ComboBoxItem Content="学号降序"/>
                <ComboBoxItem Content="姓名升序"/>
                <ComboBoxItem Content="院系升序"/>
                <ComboBoxItem Content="班级升序"/>
            </ComboBox>
            <TextBlock Text="每页：" VerticalAlignment="Center" FontSize="14" Margin="20,0,10,0"/>
            <ComboBox x:Name="cmbPageSize" Width="90" Height="32" FontSize="14" SelectionChanged="cmbPageSize_SelectionChanged">
                <ComboBoxItem Content="10" IsSelected="True"/>
                <ComboBoxItem Content="20"/>
                <ComboBoxItem Content="50"/>
            </ComboBox>
            <Button Content="上一页" Style="{StaticResource ButtonStyle}" Click="btnPrevPage_Click"/>
            <Button Content="下一页" Style="{StaticResource ButtonStyle}" Click="btnNextPage_Click"/>
            <TextBlock x:Name="txtPageInfo" Text="第 1/1 页，共 0 条" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- 数据列表 -->
        <DataGrid x:Name="dataGrid" Grid.Row="3" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5"
                  RowHeight="35"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="学号" Binding="{Binding StudentNo}" Width="100"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100"/>
                <DataGridTextColumn Header="性别" Binding="{Binding Gender}" Width="60"/>
                <DataGridTextColumn Header="出生日期" Binding="{Binding BirthDate, StringFormat='yyyy-MM-dd'}" Width="120"/>
                <DataGridTextColumn Header="身份证号" Binding="{Binding IdCard}" Width="180"/>
                <DataGridTextColumn Header="民族" Binding="{Binding Nation}" Width="80"/>
                <DataGridTextColumn Header="政治面貌" Binding="{Binding PoliticalStatus}" Width="100"/>
                <DataGridTextColumn Header="联系电话" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="院系" Binding="{Binding Department}" Width="120"/>
                <DataGridTextColumn Header="专业" Binding="{Binding Major}" Width="120"/>
                <DataGridTextColumn Header="班级" Binding="{Binding Class}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
