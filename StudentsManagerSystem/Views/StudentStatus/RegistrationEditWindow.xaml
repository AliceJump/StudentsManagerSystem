<Window x:Class="StudentsManagerSystem.Views.StudentStatus.RegistrationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学生登记" Height="360" Width="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="学号:" VerticalAlignment="Center" />
        <TextBox x:Name="txtStudentNo" Grid.Row="0" Grid.Column="1" Margin="4" />

        <Label Grid.Row="1" Grid.Column="0" Content="姓名:" VerticalAlignment="Center" />
        <TextBox x:Name="txtStudentName" Grid.Row="1" Grid.Column="1" Margin="4" />

        <Label Grid.Row="2" Grid.Column="0" Content="注册日期:" VerticalAlignment="Center" />
        <DatePicker x:Name="dpRegistrationDate" Grid.Row="2" Grid.Column="1" Margin="4" />

        <Label Grid.Row="3" Grid.Column="0" Content="学年:" VerticalAlignment="Center" />
        <TextBox x:Name="txtAcademicYear" Grid.Row="3" Grid.Column="1" Margin="4" />

        <Label Grid.Row="4" Grid.Column="0" Content="学期:" VerticalAlignment="Center" />
        <ComboBox x:Name="cmbSemester" Grid.Row="4" Grid.Column="1" Margin="4" />

        <Label Grid.Row="5" Grid.Column="0" Content="备注:" VerticalAlignment="Top" />
        <TextBox x:Name="txtRemarks" Grid.Row="5" Grid.Column="1" Margin="4" AcceptsReturn="True" Height="100" />

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="btnOk" Width="90" Margin="4" Click="btnOk_Click">确定</Button>
            <Button Width="90" Margin="4" Click="btnCancel_Click">取消</Button>
        </StackPanel>
    </Grid>
</Window>
