<Page x:Class="StudentsManagerSystem.Views.Query.QueryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudentsManagerSystem.Views.Query"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1100">

    <Page.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 查询条件区 -->
        <Border Grid.Row="0" Background="#F8F9FA" Padding="20" CornerRadius="5" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="查询类型：" 
                           VerticalAlignment="Center" FontSize="14" Margin="0,5"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbQueryType" 
                          Height="32" FontSize="14" Margin="0,5"
                          SelectionChanged="cmbQueryType_SelectionChanged">
                    <ComboBoxItem Content="按学生信息查询" IsSelected="True"/>
                    <ComboBoxItem Content="按院系统计"/>
                    <ComboBoxItem Content="按专业统计"/>
                    <ComboBoxItem Content="按班级统计"/>
                    <ComboBoxItem Content="成绩统计"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="学号：" 
                           VerticalAlignment="Center" FontSize="14" Margin="0,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtStudentNo" 
                         Height="32" FontSize="14" Margin="0,5" 
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="姓名：" 
                           VerticalAlignment="Center" FontSize="14" Margin="10,5,0,5"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="txtName" 
                         Height="32" FontSize="14" Margin="0,5" 
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="院系：" 
                           VerticalAlignment="Center" FontSize="14" Margin="0,5"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbDepartment" 
                          Height="32" FontSize="14" Margin="0,5">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="计算机学院"/>
                    <ComboBoxItem Content="电子信息学院"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="班级：" 
                           VerticalAlignment="Center" FontSize="14" Margin="10,5,0,5"/>
                <ComboBox Grid.Row="2" Grid.Column="3" x:Name="cmbClass" 
                          Height="32" FontSize="14" Margin="0,5">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="软工2024-1班"/>
                    <ComboBoxItem Content="软工2024-2班"/>
                </ComboBox>

                <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" 
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="查询" Style="{StaticResource ButtonStyle}" Click="btnQuery_Click"/>
                        <Button Content="重置" Click="btnReset_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                <Setter Property="Background" Value="#95A5A6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7F8C8D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                        <Button Content="导出" Click="btnExport_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                <Setter Property="Background" Value="#27AE60"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#229954"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 统计信息区 -->
        <Border Grid.Row="1" Background="#ECF0F1" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="查询结果统计：" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtStatistics" Text="共找到 0 条记录" 
                           FontSize="14" VerticalAlignment="Center" 
                           Margin="20,0,0,0" Foreground="#E74C3C"/>
            </StackPanel>
        </Border>

        <!-- 数据列表 -->
        <DataGrid x:Name="dataGrid" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5"
                  RowHeight="35"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="学号" Binding="{Binding StudentNo}" Width="100"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100"/>
                <DataGridTextColumn Header="性别" Binding="{Binding Gender}" Width="60"/>
                <DataGridTextColumn Header="院系" Binding="{Binding Department}" Width="120"/>
                <DataGridTextColumn Header="专业" Binding="{Binding Major}" Width="150"/>
                <DataGridTextColumn Header="班级" Binding="{Binding Class}" Width="120"/>
                <DataGridTextColumn Header="联系电话" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="入学日期" Binding="{Binding EnrollmentDate, StringFormat='yyyy-MM-dd'}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
